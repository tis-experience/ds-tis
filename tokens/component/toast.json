{
  "component": {
    "toast": {
      "padding": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.space.md}",
          "$description": "Padding do Toast."
        }
      },
      "gap": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.space.sm}",
          "$description": "Gap horizontal do Toast."
        }
      },
      "stack": {
        "gap": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.sm}",
            "$description": "Gap vertical entre toasts na fila."
          }
        }
      },
      "actions": {
        "gap": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.sm}",
            "$description": "Gap horizontal entre Action 1 e Action 2."
          }
        },
        "padding-top": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.sm}",
            "$description": "Padding-top da fileira Actions (espaçamento acima dos CTAs)."
          }
        }
      },
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.radius.lg}",
          "$description": "Radius do Toast."
        }
      },
      "border-width": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.border.width.default}",
          "$description": "Border width do Toast."
        }
      },
      "shadow": {
        "default": {
          "$type": "shadow",
          "$value": "{semantic.shadow.overlay}",
          "$description": "Elevação do Toast — Effect Style elevation/2 (--ds-shadow-md via semantic.shadow.overlay)."
        }
      },
      "icon": {
        "size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.sm}",
            "$description": "Tamanho do ícone Toast (fixo por Type, não escolhível)."
          }
        },
        "color": {
          "success": {
            "solid": {
              "$value": "{semantic.icon.color.success-contrast}",
              "$type": "color"
            },
            "subtle": {
              "$value": "{semantic.icon.color.success}",
              "$type": "color"
            }
          },
          "warning": {
            "solid": {
              "$value": "{semantic.icon.color.warning-contrast}",
              "$type": "color"
            },
            "subtle": {
              "$value": "{semantic.icon.color.warning}",
              "$type": "color"
            }
          },
          "error": {
            "solid": {
              "$value": "{semantic.icon.color.error-contrast}",
              "$type": "color"
            },
            "subtle": {
              "$value": "{semantic.icon.color.error}",
              "$type": "color"
            }
          },
          "info": {
            "solid": {
              "$value": "{semantic.icon.color.info-contrast}",
              "$type": "color"
            },
            "subtle": {
              "$value": "{semantic.icon.color.default}",
              "$type": "color"
            }
          }
        },
        "stroke-width": {
          "default": {
            "$value": "{semantic.icon.stroke-width.regular.20}",
            "$type": "dimension"
          }
        }
      },
      "content": {
        "gap": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.xs}",
            "$description": "Gap vertical do content Toast (title, description, actions)."
          }
        }
      },
      "title": {
        "font-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.font-size.sm}"
          }
        },
        "line-height": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.line-height.sm}"
          }
        },
        "font-weight": {
          "default": {
            "$type": "number",
            "$value": "{semantic.typography.body.font-weight.bold}"
          }
        },
        "color": {
          "success": {
            "solid": {
              "$value": "{semantic.feedback.success.content-contrast}",
              "$type": "color"
            }
          },
          "subtle": {
            "$value": "{semantic.content.strong}",
            "$type": "color"
          },
          "warning": {
            "solid": {
              "$value": "{semantic.feedback.warning.content-contrast}",
              "$type": "color"
            }
          },
          "error": {
            "solid": {
              "$value": "{semantic.feedback.error.content-contrast}",
              "$type": "color"
            }
          },
          "info": {
            "solid": {
              "$value": "{semantic.feedback.info.content-contrast}",
              "$type": "color"
            }
          }
        }
      },
      "description": {
        "font-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.font-size.sm}"
          }
        },
        "line-height": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.line-height.sm}"
          }
        },
        "font-weight": {
          "default": {
            "$type": "number",
            "$value": "{semantic.typography.body.font-weight.regular}"
          }
        },
        "color": {
          "success": {
            "solid": {
              "$value": "{semantic.feedback.success.content-contrast}",
              "$type": "color"
            }
          },
          "subtle": {
            "$value": "{semantic.content.strong}",
            "$type": "color"
          },
          "warning": {
            "solid": {
              "$value": "{semantic.feedback.warning.content-contrast}",
              "$type": "color"
            }
          },
          "error": {
            "solid": {
              "$value": "{semantic.feedback.error.content-contrast}",
              "$type": "color"
            }
          },
          "info": {
            "solid": {
              "$value": "{semantic.feedback.info.content-contrast}",
              "$type": "color"
            }
          }
        }
      },
      "close": {
        "icon-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.sm}"
          }
        },
        "icon": {
          "color": {
            "success": {
              "solid": {
                "$value": "{semantic.icon.color.success-contrast}",
                "$type": "color"
              }
            },
            "warning": {
              "solid": {
                "$value": "{semantic.icon.color.warning-contrast}",
                "$type": "color"
              }
            },
            "error": {
              "solid": {
                "$value": "{semantic.icon.color.error-contrast}",
                "$type": "color"
              }
            },
            "info": {
              "solid": {
                "$value": "{semantic.icon.color.info-contrast}",
                "$type": "color"
              }
            },
            "subtle": {
              "$value": "{semantic.icon.color.default}",
              "$type": "color"
            }
          },
          "stroke-width": {
            "default": {
              "$value": "{semantic.icon.stroke-width.regular.20}",
              "$type": "dimension"
            }
          }
        }
      },
      "bg": {
        "success": {
          "solid": {
            "$value": "{semantic.feedback.success.background.default}",
            "$type": "color"
          },
          "subtle": {
            "$value": "{semantic.feedback.success.background.subtle}",
            "$type": "color"
          }
        },
        "warning": {
          "solid": {
            "$value": "{semantic.feedback.warning.background.default}",
            "$type": "color"
          },
          "subtle": {
            "$value": "{semantic.feedback.warning.background.subtle}",
            "$type": "color"
          }
        },
        "error": {
          "solid": {
            "$value": "{semantic.feedback.error.background.default}",
            "$type": "color"
          },
          "subtle": {
            "$value": "{semantic.feedback.error.background.subtle}",
            "$type": "color"
          }
        },
        "info": {
          "solid": {
            "$value": "{semantic.feedback.info.background.default}",
            "$type": "color"
          },
          "subtle": {
            "$value": "{semantic.feedback.info.background.subtle}",
            "$type": "color"
          }
        }
      },
      "border-color": {
        "success": {
          "subtle": {
            "$value": "{semantic.feedback.success.border-default}",
            "$type": "color"
          }
        },
        "warning": {
          "subtle": {
            "$value": "{semantic.feedback.warning.border-default}",
            "$type": "color"
          }
        },
        "error": {
          "subtle": {
            "$value": "{semantic.feedback.error.border-default}",
            "$type": "color"
          }
        },
        "info": {
          "subtle": {
            "$value": "{semantic.feedback.info.border-default}",
            "$type": "color"
          }
        }
      },
      "action": {
        "color": {
          "subtle": {
            "$value": "{semantic.content.strong}",
            "$type": "color",
            "$description": "Cor do label das actions no estilo Subtle (alinhada ao título)."
          },
          "success": {
            "solid": {
              "$value": "{semantic.feedback.success.content-contrast}",
              "$type": "color",
              "$description": "Cor das actions no Solid success."
            }
          },
          "warning": {
            "solid": {
              "$value": "{semantic.feedback.warning.content-contrast}",
              "$type": "color"
            }
          },
          "error": {
            "solid": {
              "$value": "{semantic.feedback.error.content-contrast}",
              "$type": "color"
            }
          },
          "info": {
            "solid": {
              "$value": "{semantic.feedback.info.content-contrast}",
              "$type": "color"
            }
          }
        }
      }
    }
  }
}
